{
  "root": false,
  "extends": "//",

  "files": {
    "includes": [
      "**/*.{ts,tsx}",
      "!**/*.d.ts",
      "!dist",
      "!node_modules",
      "!**/*.js",
      "!**/.next",
      "!**/.storybook",
      "!**/.turbo",
      "!**/.vscode"
    ]
  },

  "formatter": {
    "enabled": true
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "a11y": "warn",
      "correctness": {
        "useHookAtTopLevel": "error",
        "useExhaustiveDependencies": "error",
        "noUnusedVariables": "warn",
        "noUnusedImports": "warn"
      },
      "style": {
        "noRestrictedImports": {
          "level": "error",
          "options": {
            "paths": {
              "lucide-react": "직접 'lucide-react'를 참조하지 마세요. '@moum-zip/ui/icons'를 사용해야 합니다."
            }
          }
        }
      },

      "suspicious": {
        "noConfusingVoidType": "off",
        "noConsole": "warn"
      },

      "nursery": {
        "noFloatingPromises": "error",
        "useSortedClasses": {
          "level": "error",
          "fix": "safe",
          "options": {
            "attributes": ["classList"],
            "functions": ["clsx", "cva", "cn"]
          }
        }
      }
    }
  },
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "defaultBranch": "develop",
    "useIgnoreFile": true
  },
  "css": {
    "parser": {
      "tailwindDirectives": true
    }
  },
  "assist": {
    "actions": {
      "recommended": true,
      "source": {
        "organizeImports": "on"
      }
    }
  }
}
