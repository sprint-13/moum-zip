{
  "root": false,
  "extends": "//",
  "formatter": {
    "enabled": true
  },
  "linter": {
    "rules": {
      "nursery": {
        "useSortedClasses": {
          "level": "error",
          "fix": "safe",
          "options": {
            "attributes": ["classList"],
            "functions": ["clsx", "cva", "cn"]
          }
        }
      }
    }
  },
  "files": {
    "includes": ["**", "!src/components/shadcn"]
  },
  "css": {
    "parser": {
      "tailwindDirectives": true
    }
  }
}
